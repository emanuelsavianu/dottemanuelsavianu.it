// aggregateRating Schema Template for visite-private.html
// ==================================================================
//
// INSTRUCTIONS:
// 1. Log in to Google Business Profile (GBP) at https://business.google.com
// 2. Navigate to "Info" → Look for "Rating" section
// 3. Note down: Star Rating (e.g., 4.8), Total Review Count (e.g., 23)
// 4. Replace [RATING_VALUE], [REVIEW_COUNT] below with actual GBP data
// 5. Add this block to visite-private.html LocalBusiness schema (around line 100)
// 6. Update quarterly as reviews accumulate
//
// ==================================================================

// OPTION 1: Add to LocalBusiness schema on visite-private.html
// Location: After "areaServed" property, before closing "}"

{
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MedicalOrganization"],
  "name": "Studio Medico Ippocrate — Dott. Emanuel Savianu",
  "url": "https://dottemanuelsavianu.it/visite-private.html",
  "telephone": "+3905751713428",
  "email": "segreteria@savianu.it",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Via Ubaldo Pasqui 38",
    "addressLocality": "Arezzo",
    "postalCode": "52100",
    "addressCountry": "IT"
  },
  "areaServed": {
    "@type": "City",
    "name": "Arezzo"
  },

  // ========= ADD THIS BLOCK =========
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "[RATING_VALUE]",    // e.g., 4.8
    "reviewCount": "[REVIEW_COUNT]",    // e.g., 23
    "bestRating": 5
  },
  // ==================================

  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servizi di Certificazione Medico-Legale",
    "itemListElement": [
      // ... rest of schema
    ]
  }
}


// ==================================================================
// OPTION 2: Add to homepage MedicalClinic schema (index.html)
// Location: Around line 82, after "openingHours"

{
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "name": "Studio Medico Ippocrate",
  "medicalSpecialty": "General Practice",
  "description": "Studio medico del Dott. Emanuel Savianu, Medico di Medicina Generale e Certificatore INPS ad Arezzo.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Via Ubaldo Pasqui 38",
    "addressLocality": "Arezzo",
    "postalCode": "52100",
    "addressRegion": "Toscana",
    "addressCountry": "IT"
  },
  "telephone": "+3905751713428",
  "url": "https://dottemanuelsavianu.it",
  "openingHours": ["Mo 08:00-13:00", "Tu 08:00-13:00", "We 08:00-13:00", "Th 08:00-13:00", "Fr 08:00-13:00"],
  "hasMap": "https://maps.google.com/?q=Via+Ubaldo+Pasqui+38+Arezzo",

  // ========= ADD THIS BLOCK =========
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "[RATING_VALUE]",    // e.g., 4.8
    "reviewCount": "[REVIEW_COUNT]",    // e.g., 23
    "bestRating": 5
  }
  // ==================================
}


// ==================================================================
// GBP Data Lookup Instructions
// ==================================================================
//
// 1. Go to https://business.google.com/u/0/dashboard
// 2. Select "Studio Medico Ippocrate" from the list
// 3. Left sidebar → Click "Info"
// 4. Scroll to "Rating" section
// 5. You'll see:
//    - Star rating (e.g., ★★★★★ 4.8)
//    - Total reviews (e.g., "23 reviews")
// 6. Copy these values into aggregateRating above
//
// Example found on GBP:
//   Rating: 4.8 stars
//   Total Reviews: 23
//   → Use: "ratingValue": "4.8", "reviewCount": "23"
//
// ==================================================================
// Validation
// ==================================================================
//
// After adding aggregateRating:
// 1. Validate JSON-LD at https://validator.schema.org/
// 2. Test rich results at https://search.google.com/test/rich-results
// 3. Check Google Search Console for "Rich Results" status
// 4. Monitor if rating stars appear in Google search results within 1-2 weeks
//
// ==================================================================
// Update Schedule
// ==================================================================
//
// Quarterly review updates (every 3 months):
//   - Check GBP for new review count
//   - Update ratingValue if rating changed
//   - Update reviewCount in schema
//   - Commit to git with message: "Update aggregateRating schema: [X.X] stars, [N] reviews"
//
// This keeps schema data fresh and helps Google understand review velocity.
//
// ==================================================================
